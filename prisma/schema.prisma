generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CandidateProfile {
  id                    String   @id @default(cuid())
  fullName              String
  preferredName         String?
  location              String
  targetSalaryGrossNis  Int?
  minimumSalaryGrossNis Int?
  availability          String?
  degreeStatus          String?
  expectedCompletion    String?
  mobility              String?
  languages             Json
  technicalSkills       Json
  softSkills            Json
  fieldExperience       Json
  education             Json
  certificates          Json
  githubProjects        Json
  portfolioLinks        Json
  sourceNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  sourceLinks           ProfileSourceLink[]
}

model Job {
  id               String             @id @default(cuid())
  title            String
  company          String?
  source           String
  sourceUrl        String?
  location         String?
  language         String?
  roleCategory     String?
  rawDescription   String
  salaryText       String?
  status           String             @default("FOUND")
  validationStatus String             @default("UNREVIEWED")
  forbiddenFlags   Json?
  allowedSignals   Json?
  riskNotes        String?
  nextActionAt     DateTime?
  nextActionNote   String?
  lastContactedAt  DateTime?
  priority         String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  events           ApplicationEvent[]
  applicationPacket ApplicationPacket?
}

model GmailJobAlert {
  id         String             @id @default(cuid())
  provider   String?
  sender     String?
  subject    String?
  receivedAt DateTime?
  rawText    String
  notes      String?
  status     String             @default("REVIEW")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  leads      JobDiscoveryLead[]
}

model JobDiscoveryLead {
  id               String         @id @default(cuid())
  sourceType       String         @default("GMAIL_ALERT")
  provider         String?
  gmailAlertId     String?
  gmailAlert       GmailJobAlert? @relation(fields: [gmailAlertId], references: [id], onDelete: Cascade)
  title            String
  company          String?
  location         String?
  sourceUrl        String?
  rawSnippet       String
  rawText          String?
  validationStatus String         @default("UNREVIEWED")
  forbiddenFlags   Json?
  allowedSignals   Json?
  riskNotes        String?
  status           String         @default("NEW")
  importedJobId    String?
  duplicateOfJobId String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([gmailAlertId])
  @@index([status])
  @@index([validationStatus])
}

model ApplicationEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String
  notes     String?
  createdAt DateTime @default(now())
}

model SourceFile {
  id              String   @id @default(cuid())
  filename        String
  type            String
  path            String?
  uploadMimeType  String?
  uploadSizeBytes Int?
  uploadedAt      DateTime?
  url             String?
  extractedText   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profileLinks    ProfileSourceLink[]
}

model ProfileSourceLink {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sourceId    String
  source      SourceFile       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  targetField String
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([profileId, sourceId, targetField])
  @@index([profileId])
  @@index([sourceId])
}

model ApplicationPacket {
  id                     String   @id @default(cuid())
  jobId                  String   @unique
  job                    Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status                 String   @default("DRAFT")
  cvLanguage             String?
  applicationDecision    String?
  checklist              Json?
  missingItems           Json?
  profileEvidenceSummary Json?
  cvTailoringNotes       String?
  skillsToHighlight      String?
  experienceBulletsDraft String?
  coverLetterDraft       String?
  recruiterMessageDraft  String?
  followUpPlan           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  aiDraftRuns            AiDraftRun[]

  @@index([jobId])
}

model AiDraftRun {
  id                  String            @id @default(cuid())
  applicationPacketId String
  applicationPacket   ApplicationPacket @relation(fields: [applicationPacketId], references: [id], onDelete: Cascade)
  kind                String
  status              String            @default("DRAFT")
  model               String?
  promptVersion       String
  inputSummary        Json?
  output              Json?
  error               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([applicationPacketId])
}
